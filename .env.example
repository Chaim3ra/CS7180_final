NREL_API_KEY=your_nrel_api_key_here
PECAN_STREET_USERNAME=your_dataport_email_here
PECAN_STREET_PASSWORD=your_dataport_password_here
PECAN_STREET_DB_HOST=your_db_host_here
PECAN_STREET_DB_PORT=5432
PECAN_STREET_DB_NAME=your_db_name_here

# AWS credentials — all data streams from S3, no local data needed
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_DEFAULT_REGION=us-east-2

# S3 bucket and prefixes — data streams directly, no dvc pull required
S3_BUCKET=cs7180-final-project
S3_RAW_PREFIX=raw
S3_PROCESSED_PREFIX=data/processed
